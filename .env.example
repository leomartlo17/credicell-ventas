# Copia este archivo como .env.local y rellena los valores reales.
# NO subas .env.local al repositorio.

# ============================================================
# NEXTAUTH — secreto para firmar tokens de sesión
# Genera uno con: openssl rand -base64 32
# ============================================================
NEXTAUTH_SECRET=reemplazar-con-un-string-aleatorio-largo
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# GOOGLE OAUTH — para login con cuenta Google
# Crea credenciales en https://console.cloud.google.com/
# APIs y servicios → Credenciales → OAuth 2.0 Client ID
# Tipo: Aplicación web
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
# ============================================================
GOOGLE_CLIENT_ID=reemplazar
GOOGLE_CLIENT_SECRET=reemplazar

# ============================================================
# GOOGLE SHEETS API — para leer/escribir en los libros
# Crea una Service Account en https://console.cloud.google.com/
# Descarga el JSON de credenciales y pega los campos aquí
# Comparte los libros de Sheets con el email de la Service Account
# ============================================================
GOOGLE_SHEETS_CLIENT_EMAIL=service-account@proyecto.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ============================================================
# IDs de los libros de cada sede
# ============================================================
LIBRO_SAN_ESTEBAN=1k6Wr4wjFmiuAUSj26Uqi61DV7vaBu6h7ugt-pOpYSZM
LIBRO_PITALITO=1ELtLc0qGDQiUCCAtOgKG-vKxCpvOs8XMgvqqP5kcBcg
LIBRO_CARTERA=1nZ8p7IE7FaCrJ5Yi_mgpLvvfxDeO_AWkEKKUMMOGdDs

# ============================================================
# DRIVE FOLDER ID para subir fotos (FASE 6)
